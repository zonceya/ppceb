@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">Welcome to PPECB Assessment</h1>
    <p>Product and Category Management System</p>
    
    @if (User.Identity.IsAuthenticated)
    {
        <div class="row mt-5">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Categories</h5>
                        <p class="card-text">Manage your product categories</p>
                        <a href="/Categories" class="btn btn-primary">Go to Categories</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Products</h5>
                        <p class="card-text">Manage your products</p>
                        <a href="/Products" class="btn btn-primary">Go to Products</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="mt-5">
            <a href="/Account/Login" class="btn btn-primary">Login</a>
            <a href="/Account/Register" class="btn btn-secondary">Register</a>
        </div>
    }
</div>