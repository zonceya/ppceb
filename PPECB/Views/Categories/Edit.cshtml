@model PPECB.Domain.Entities.Category

@{
    ViewData["Title"] = "Edit Category";
}

<h2>Edit Category</h2>

<form method="post">
    <input type="hidden" asp-for="Id" />
    
    <div class="form-group mb-3">
        <label asp-for="CategoryCode"></label>
        <input asp-for="CategoryCode" class="form-control" placeholder="ABC123" />
        <span asp-validation-for="CategoryCode" class="text-danger"></span>
        <small class="text-muted">Format: 3 letters + 3 numbers (e.g., ABC123)</small>
    </div>
    
    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Categories" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}