@model IEnumerable<PPECB.Domain.Entities.Product>

@{
    ViewData["Title"] = "Products";
}

<h2>Products</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Html.Raw(TempData["Success"])
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @Html.Raw(TempData["Error"])
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row mb-3">
    <div class="col-md-6">
        <a href="/Products/Create" class="btn btn-primary">Create New Product</a>
        <a href="/Products/ExportExcel" class="btn btn-success ms-2">Export to Excel</a>
        <button type="button" class="btn btn-info ms-2" data-bs-toggle="modal" data-bs-target="#importModal">
            Import from Excel
        </button>
        <a href="/Products/DownloadTemplate" class="btn btn-secondary ms-2">Download Template</a>
    </div>
    <div class="col-md-6">
        <form method="get" class="form-inline float-end">
            <select name="categoryId" class="form-select me-2" onchange="this.form.submit()">
                <option value="">All Categories</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories as List<PPECB.Domain.Entities.Category>)
                    {
                        if (ViewBag.SelectedCategory == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                }
            </select>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <strong>No products found.</strong> Click "Create New Product" to add your first product, or use "Import from Excel" to bulk upload.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Product Code</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(product.ImagePath))
                            {
                                <img src="@product.ImagePath" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" />
                            }
                            else
                            {
                                <span class="text-muted">No image</span>
                            }
                        </td>
                        <td><code>@product.ProductCode</code></td>
                        <td>@product.Name</td>
                        <td>@(product.Category?.Name ?? "N/A")</td>
                        <td class="text-end">@product.Price.ToString("C")</td>
                        <td>
                            <a href="/Products/Edit/@product.Id" class="btn btn-sm btn-warning">Edit</a>
                            <button type="button" class="btn btn-sm btn-danger" onclick="confirmDelete(@product.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&categoryId=@ViewBag.SelectedCategory">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importModalLabel">Import Products from Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/Products/ImportExcel" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="excelFile" class="form-label">Select Excel File</label>
                        <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" required />
                        <div class="form-text">
                            <a href="/Products/DownloadTemplate">Download sample template</a> to see the correct format.
                        </div>
                    </div>
                    <div class="alert alert-info">
                        <strong>File Format:</strong>
                        <hr />
                        <ul class="mb-0">
                            <li><strong>Column A:</strong> Category Name (must match existing category)</li>
                            <li><strong>Column B:</strong> Product Name (required)</li>
                            <li><strong>Column C:</strong> Price (required, e.g., 99.99)</li>
                            <li><strong>Column D:</strong> Description (optional)</li>
                        </ul>
                    </div>
                    <div class="alert alert-warning">
                        <strong>Note:</strong> Product codes are auto-generated automatically. The first row is treated as headers and will be skipped.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Form -->
<form id="deleteForm" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this product?')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').action = '/Products/Delete/' + id;
                document.getElementById('deleteForm').submit();
            }
        }
        
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                alert.style.transition = 'opacity 0.5s';
                alert.style.opacity = '0';
                setTimeout(function() { alert.remove(); }, 500);
            });
        }, 5000);
        
        // Auto-dismiss modal on success (optional)
        @if (TempData["Success"] != null)
        {
                <text>
                    var modal = bootstrap.Modal.getInstance(document.getElementById('importModal'));
                    if (modal) modal.hide();
                </text>
        }
    </script>
}